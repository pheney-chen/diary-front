.page {
  min-height: 100vh;
  background: #f7f7f7;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #4A90E2, #357ABD);
  padding: 60rpx 30rpx 80rpx;
  color: #fff;
}

.avatar-section {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 60rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
}

.signature {
  font-size: 24rpx;
  opacity: 0.8;
}

.stats-section {
  padding: 0 24rpx;
  margin-top: -40rpx;
}

.stats-card {
  padding: 30rpx;
}

.stats-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.stats-grid {
  display: flex;
  margin-bottom: 30rpx;
}

.stat-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 600;
  color: #4A90E2;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

.type-stats {
  display: flex;
  justify-content: space-around;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.type-icon {
  font-size: 36rpx;
}

.type-name {
  font-size: 22rpx;
  color: #999;
}

.type-count {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

.menu-section {
  padding: 24rpx;
}

.menu-card {
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-text.danger {
  color: #E74C3C;
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.menu-value {
  font-size: 24rpx;
  color: #999;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.footer {
  text-align: center;
  padding: 40rpx 0;
}

.version {
  font-size: 22rpx;
  color: #ccc;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  margin: 0 40rpx;
  overflow: hidden;
}

.modal-header {
  padding: 30rpx;
  text-align: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-body {
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.about-text {
  font-size: 28rpx;
  color: #666;
  text-align: center;
}

.modal-footer {
  padding: 20rpx 30rpx 30rpx;
}

.modal-btn {
  padding: 24rpx;
  background: linear-gradient(135deg, #4A90E2, #357ABD);
  color: #fff;
  text-align: center;
  border-radius: 50rpx;
  font-size: 30rpx;
}
