.page {
  min-height: 100vh;
  background: #f7f7f7;
  padding-bottom: 140rpx;
}

.diary-container {
  padding: 30rpx;
}

.diary-header {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 24rpx;
}

.diary-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.diary-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.meta-time {
  font-size: 24rpx;
  color: #999;
}

.meta-mood {
  font-size: 32rpx;
}

.diary-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  font-size: 24rpx;
  color: #4A90E2;
  background: #E8F0FE;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.diary-content {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.content-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
  margin-bottom: 30rpx;
}

.voice-player {
  display: flex;
  align-items: center;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.voice-btn {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #4A90E2, #357ABD);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.play-icon {
  font-size: 36rpx;
  color: #fff;
}

.voice-info {
  flex: 1;
}

.voice-progress {
  margin-bottom: 12rpx;
}

.progress-bar {
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4A90E2, #357ABD);
  border-radius: 4rpx;
  transition: width 0.1s;
}

.voice-duration {
  font-size: 24rpx;
  color: #999;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 30rpx;
}

.grid-image {
  width: 210rpx;
  height: 210rpx;
  border-radius: 12rpx;
}

.diary-video {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.diary-footer {
  padding: 20rpx 0;
}

.update-time {
  font-size: 22rpx;
  color: #ccc;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.05);
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  border-radius: 50rpx;
  background: #f5f5f5;
}

.action-btn.primary {
  background: linear-gradient(135deg, #4A90E2, #357ABD);
}

.action-btn.primary .action-text,
.action-btn.primary .action-icon {
  color: #fff;
}

.action-icon {
  font-size: 32rpx;
}

.action-text {
  font-size: 28rpx;
  color: #666;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  color: #999;
  font-size: 28rpx;
}

/* AI 分析面板 */
.ai-panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.ai-panel {
  width: 100%;
  max-height: 80vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
}

.ai-panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.ai-panel-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.ai-panel-close {
  width: 56rpx;
  height: 56rpx;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #999;
}

.ai-mode-section {
  margin-bottom: 30rpx;
}

.ai-section-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
  display: block;
}

.ai-mode-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ai-mode-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.ai-mode-item.selected {
  background: #E8F0FE;
  border-color: #4A90E2;
}

.mode-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.mode-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.mode-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.mode-desc {
  font-size: 22rpx;
  color: #999;
  line-height: 1.4;
}

.ai-action-section {
  margin-bottom: 30rpx;
}

.ai-analyze-btn {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #4A90E2, #357ABD);
  color: #fff;
  text-align: center;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.ai-analyze-btn.loading {
  background: #ccc;
}

.ai-result-section {
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 24rpx;
}

.ai-result-header {
  margin-bottom: 16rpx;
}

.ai-result-mode {
  font-size: 26rpx;
  font-weight: 600;
  color: #4A90E2;
}

.ai-result-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  margin-bottom: 20rpx;
}

.ai-result-actions {
  display: flex;
  gap: 16rpx;
}

.ai-copy-btn {
  flex: 1;
  padding: 20rpx;
  background: #fff;
  border: 2rpx solid #4A90E2;
  border-radius: 50rpx;
  text-align: center;
}

.ai-copy-btn text {
  font-size: 26rpx;
  color: #4A90E2;
}
