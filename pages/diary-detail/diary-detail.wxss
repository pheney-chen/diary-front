.page {
  min-height: 100vh;
  background: #f7f7f7;
  padding-bottom: 140rpx;
}

.diary-container {
  padding: 30rpx;
}

.diary-header {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 24rpx;
}

.diary-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.diary-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.meta-time {
  font-size: 24rpx;
  color: #999;
}

.meta-mood {
  font-size: 32rpx;
}

.diary-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  font-size: 24rpx;
  color: #4A90E2;
  background: #E8F0FE;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.diary-content {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.content-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
  margin-bottom: 30rpx;
}

.voice-player {
  display: flex;
  align-items: center;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.voice-btn {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #4A90E2, #357ABD);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.play-icon {
  font-size: 36rpx;
  color: #fff;
}

.voice-info {
  flex: 1;
}

.voice-progress {
  margin-bottom: 12rpx;
}

.progress-bar {
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4A90E2, #357ABD);
  border-radius: 4rpx;
  transition: width 0.1s;
}

.voice-duration {
  font-size: 24rpx;
  color: #999;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 30rpx;
}

.grid-image {
  width: 210rpx;
  height: 210rpx;
  border-radius: 12rpx;
}

.diary-video {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.diary-footer {
  padding: 20rpx 0;
}

.update-time {
  font-size: 22rpx;
  color: #ccc;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.05);
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  border-radius: 50rpx;
  background: #f5f5f5;
}

.action-btn.primary {
  background: linear-gradient(135deg, #4A90E2, #357ABD);
}

.action-btn.primary .action-text,
.action-btn.primary .action-icon {
  color: #fff;
}

.action-icon {
  font-size: 32rpx;
}

.action-text {
  font-size: 28rpx;
  color: #666;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  color: #999;
  font-size: 28rpx;
}
