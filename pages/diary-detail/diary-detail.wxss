.page {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 140rpx;
}

.page-actions {
  position: fixed;
  top: 0;
  right: 0;
  z-index: 100;
  padding: 20rpx 30rpx;
}

.more-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-card);
  border-radius: 50%;
  box-shadow: var(--shadow-card);
  font-size: 32rpx;
  color: var(--text-secondary);
  letter-spacing: 2rpx;
}

.diary-container {
  padding: 30rpx;
}

.diary-header {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 24rpx;
}

.diary-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.diary-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.meta-time {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.meta-mood {
  font-size: 32rpx;
}

.diary-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  font-size: 24rpx;
  color: var(--primary-color);
  background: var(--primary-light);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.diary-content {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.content-text {
  font-size: 30rpx;
  color: var(--text-primary);
  line-height: 1.8;
  margin-bottom: 30rpx;
}

.content-voice {
  margin-bottom: 30rpx;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 30rpx;
}

.grid-image {
  width: 210rpx;
  height: 210rpx;
  border-radius: 12rpx;
}

.diary-video {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.diary-footer {
  padding: 20rpx 0;
}

.update-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-card);
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  box-shadow: var(--shadow-bottom-bar);
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  border-radius: 50rpx;
  background: var(--bg-input);
}

.action-btn.primary {
  background: var(--primary-gradient);
}

.action-btn.primary .action-text,
.action-btn.primary .action-icon {
  color: var(--text-inverse);
}

.action-icon {
  font-size: 32rpx;
}

.action-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  color: var(--text-tertiary);
  font-size: 28rpx;
}

/* AI 分析面板 */
.ai-panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--mask-bg);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.ai-panel {
  width: 100%;
  max-height: 80vh;
  background: var(--bg-card);
  border-radius: 32rpx 32rpx 0 0;
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
}

.ai-panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.ai-panel-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.ai-panel-close {
  width: 56rpx;
  height: 56rpx;
  background: var(--bg-input);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--text-tertiary);
}

.ai-mode-section {
  margin-bottom: 30rpx;
}

.ai-section-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
  display: block;
}

.ai-mode-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ai-mode-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx;
  background: var(--bg-card-secondary);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.ai-mode-item.selected {
  background: var(--primary-light);
  border-color: var(--primary-color);
}

.mode-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.mode-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.mode-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.mode-desc {
  font-size: 22rpx;
  color: var(--text-tertiary);
  line-height: 1.4;
}

.ai-action-section {
  margin-bottom: 30rpx;
}

.ai-analyze-btn {
  width: 100%;
  padding: 28rpx;
  background: var(--primary-gradient);
  color: var(--text-inverse);
  text-align: center;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.ai-analyze-btn.loading {
  background: var(--text-tertiary);
}

.ai-result-section {
  background: var(--bg-card-secondary);
  border-radius: 16rpx;
  padding: 24rpx;
}

.ai-result-header {
  margin-bottom: 16rpx;
}

.ai-result-mode {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.ai-result-content {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.8;
  margin-bottom: 20rpx;
}

.ai-result-actions {
  display: flex;
  gap: 16rpx;
}

.ai-copy-btn {
  flex: 1;
  padding: 20rpx;
  background: var(--bg-card);
  border: 2rpx solid var(--primary-color);
  border-radius: 50rpx;
  text-align: center;
}

.ai-copy-btn text {
  font-size: 26rpx;
  color: var(--primary-color);
}
