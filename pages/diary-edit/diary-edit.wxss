.page {
  min-height: 100vh;
  background: #f7f7f7;
  padding-bottom: 140rpx;
}

.type-tabs {
  display: flex;
  background: #fff;
  padding: 20rpx 0;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.type-tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 0;
  position: relative;
}

.type-tab.active .type-name {
  color: #4A90E2;
  font-weight: 600;
}

.type-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  width: 60rpx;
  height: 6rpx;
  background: #4A90E2;
  border-radius: 3rpx;
}

.type-icon {
  font-size: 40rpx;
}

.type-name {
  font-size: 24rpx;
  color: #666;
}

.editor-container {
  padding: 24rpx;
}

.editor-card {
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.title-input {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.content-input {
  width: 100%;
  min-height: 300rpx;
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
}

.mood-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 24rpx;
}

.mood-label {
  font-size: 28rpx;
  color: #333;
}

.mood-selector {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.mood-text {
  font-size: 28rpx;
  color: #666;
}

.mood-arrow {
  font-size: 20rpx;
  color: #999;
}

.mood-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.mood-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  background: #fff;
  border: 2rpx solid transparent;
}

.mood-option.selected {
  border-color: #4A90E2;
  background: #E8F0FE;
}

.option-emoji {
  font-size: 40rpx;
}

.option-text {
  font-size: 22rpx;
  color: #666;
}

.tags-section {
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.add-tag-btn {
  font-size: 24rpx;
  color: #4A90E2;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  background: #E8F0FE;
  border-radius: 20rpx;
}

.tag-text {
  font-size: 24rpx;
  color: #4A90E2;
}

.tag-remove {
  font-size: 28rpx;
  color: #4A90E2;
  line-height: 1;
}

.tag-input-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.tag-input {
  flex: 1;
  padding: 16rpx 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.tag-add-btn {
  padding: 16rpx 32rpx;
  background: #4A90E2;
  color: #fff;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.media-section {
  margin-top: 10rpx;
}

.section-title-bar {
  margin-bottom: 16rpx;
}

.section-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.voice-section,
.images-section,
.video-section {
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.image-count {
  font-size: 24rpx;
  color: #999;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.image-preview {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.image-remove {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  line-height: 1;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.add-icon {
  font-size: 48rpx;
  color: #ccc;
}

.add-text {
  font-size: 24rpx;
  color: #999;
}

.record-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.record-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 40rpx 80rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
}

.record-btn.recording {
  background: #FFE8E8;
}

.record-icon {
  font-size: 60rpx;
}

.record-text {
  font-size: 28rpx;
  color: #666;
}

.record-btn.recording .record-text {
  color: #E74C3C;
}

.record-tip {
  font-size: 22rpx;
  color: #999;
  margin-top: 16rpx;
}

.voice-player-mini {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.play-btn {
  width: 64rpx;
  height: 64rpx;
  background: #4A90E2;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  margin-right: 20rpx;
}

.voice-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.voice-name {
  font-size: 28rpx;
  color: #333;
}

.voice-duration {
  font-size: 22rpx;
  color: #999;
}

.remove-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 36rpx;
}

.video-item {
  position: relative;
}

.video-preview {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
}

.remove-video {
  margin-top: 16rpx;
  text-align: center;
  padding: 16rpx;
  background: #FFF0F0;
  color: #E74C3C;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.video-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  gap: 12rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.05);
}

.save-btn {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #4A90E2, #357ABD);
  color: #fff;
  text-align: center;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 500;
}
