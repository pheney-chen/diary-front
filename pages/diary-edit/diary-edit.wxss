.page {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 140rpx;
}

.editor-container {
  padding: 24rpx;
}

.editor-card {
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.title-input {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.content-input {
  width: 100%;
  min-height: 300rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  line-height: 1.8;
}

.mood-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-top: 1rpx solid var(--border-color);
  margin-top: 24rpx;
}

.mood-label {
  font-size: 28rpx;
  color: var(--text-primary);
}

.mood-selector {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.mood-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.mood-arrow {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.mood-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 20rpx;
  background: var(--bg-card-secondary);
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.mood-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  background: var(--bg-card);
  border: 2rpx solid transparent;
}

.mood-option.selected {
  border-color: var(--primary-color);
  background: var(--primary-light);
}

.option-emoji {
  font-size: 40rpx;
}

.option-text {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.tags-section {
  padding-top: 24rpx;
  border-top: 1rpx solid var(--border-color);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.add-tag-btn {
  font-size: 24rpx;
  color: var(--primary-color);
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  background: var(--primary-light);
  border-radius: 20rpx;
}

.tag-text {
  font-size: 24rpx;
  color: var(--primary-color);
}

.tag-remove {
  font-size: 28rpx;
  color: var(--primary-color);
  line-height: 1;
}

.tag-input-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.tag-input {
  flex: 1;
  padding: 16rpx 24rpx;
  background: var(--bg-input);
  border-radius: 8rpx;
  font-size: 26rpx;
}

.tag-add-btn {
  padding: 16rpx 32rpx;
  background: var(--primary-color);
  color: var(--text-inverse);
  border-radius: 8rpx;
  font-size: 26rpx;
}

.media-section {
  margin-top: 10rpx;
}

.section-title-bar {
  margin-bottom: 16rpx;
}

.section-label {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.voice-section,
.images-section,
.video-section {
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.image-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.image-preview {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.image-remove {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-inverse);
  font-size: 28rpx;
  line-height: 1;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed var(--border-color);
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.add-icon {
  font-size: 48rpx;
  color: #ccc;
}

.add-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.record-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.record-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 40rpx 80rpx;
  background: var(--bg-input);
  border-radius: 20rpx;
}

.record-btn.recording {
  background: var(--danger-light);
}

.record-icon {
  font-size: 60rpx;
}

.record-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.record-btn.recording .record-text {
  color: var(--danger-color);
}

.record-tip {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 16rpx;
}

.record-wave {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  height: 60rpx;
  margin-top: 20rpx;
}

.wave-bar {
  width: 6rpx;
  background: var(--danger-color);
  border-radius: 3rpx;
  transition: height 0.2s ease;
}

.voice-item {
  margin-bottom: 16rpx;
}

.remove-voice {
  text-align: center;
  padding: 16rpx;
  background: var(--danger-light);
  color: var(--danger-color);
  border-radius: 8rpx;
  font-size: 26rpx;
}

.video-item {
  position: relative;
}

.video-preview {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
}

.remove-video {
  margin-top: 16rpx;
  text-align: center;
  padding: 16rpx;
  background: var(--danger-light);
  color: var(--danger-color);
  border-radius: 8rpx;
  font-size: 26rpx;
}

.video-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  border: 2rpx dashed var(--border-color);
  border-radius: 12rpx;
  gap: 12rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-card);
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: var(--shadow-bottom-bar);
}

.save-btn {
  width: 100%;
  padding: 28rpx;
  background: var(--primary-gradient);
  color: var(--text-inverse);
  text-align: center;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 500;
}
