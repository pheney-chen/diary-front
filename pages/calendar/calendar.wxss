.page {
  min-height: 100vh;
  background: var(--bg-page);
  padding: 24rpx;
  padding-bottom: 40rpx;
}

.calendar-card {
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.month-nav {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--bg-card-secondary);
}

.nav-arrow {
  font-size: 36rpx;
  color: var(--text-secondary);
  line-height: 1;
}

.month-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.week-header {
  display: flex;
  margin-bottom: 16rpx;
}

.week-day {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-tertiary);
  padding: 12rpx 0;
}

.calendar-body {
  display: flex;
  flex-direction: column;
}

.calendar-week {
  display: flex;
}

.calendar-day {
  flex: 1;
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  border-radius: 12rpx;
}

.day-number {
  font-size: 28rpx;
  color: var(--text-primary);
}

.calendar-day.other-month .day-number {
  color: var(--text-tertiary);
}

.calendar-day.today {
  background: var(--primary-light);
}

.calendar-day.today .day-number {
  color: var(--primary-color);
  font-weight: 600;
}

.calendar-day.selected {
  background: var(--primary-gradient);
}

.calendar-day.selected .day-number {
  color: var(--text-inverse);
  font-weight: 600;
}

.diary-dot {
  position: absolute;
  bottom: 10rpx;
  width: 12rpx;
  height: 12rpx;
  background: var(--primary-color);
  border-radius: 50%;
}

.calendar-day.selected .diary-dot {
  background: var(--text-inverse);
}

.diary-count {
  display: none;
}

.diary-section {
  margin-top: 10rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.diary-count-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.diary-item {
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.item-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-title.no-title {
  color: var(--text-tertiary);
  font-weight: normal;
}

.item-type {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  background: var(--primary-light);
  color: var(--primary-color);
  border-radius: 20rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.item-content {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.item-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.empty-day {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
  margin-bottom: 30rpx;
}

.empty-btn {
  padding: 16rpx 48rpx;
  background: var(--primary-gradient);
  color: var(--text-inverse);
  border-radius: 50rpx;
  font-size: 28rpx;
}
