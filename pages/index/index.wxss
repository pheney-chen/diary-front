.page {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 120rpx;
}

.header {
  background: linear-gradient(135deg, #4A90E2, #357ABD);
  padding: 30rpx 30rpx 24rpx;
  color: var(--text-inverse);
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.greeting-text {
  font-size: 32rpx;
  font-weight: 600;
}

.header-actions {
  display: flex;
  gap: 20rpx;
}

.icon-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  font-size: 32rpx;
}

.search-bar {
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50rpx;
  padding: 16rpx 30rpx;
  color: var(--text-inverse);
  font-size: 28rpx;
}

.search-input::placeholder {
  color: rgba(255, 255, 255, 0.6);
}

.filter-btn {
  padding: 16rpx 28rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #fff;
  white-space: nowrap;
}

.stats-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 24rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-number {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.8;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

.tags-bar {
  margin-top: 24rpx;
}

.tags-scroll {
  white-space: nowrap;
}

.tag-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 0;
}

.tag-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #fff;
  transition: all 0.2s;
}

.tag-chip.active {
  background: #fff;
  color: var(--primary-color);
  font-weight: 500;
}

.tag-count {
  font-size: 20rpx;
  opacity: 0.8;
}

.tag-chip.active .tag-count {
  color: var(--primary-color);
  opacity: 1;
}

.diary-list {
  padding: 30rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-illustration {
  width: 200rpx;
  height: 200rpx;
  background: var(--bg-card);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  box-shadow: var(--shadow-card);
}

.empty-icon {
  font-size: 100rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
  margin-bottom: 40rpx;
}

.empty-action {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 24rpx 60rpx;
  background: var(--primary-gradient);
  color: #fff;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 226, 0.3);
}

.empty-action-icon {
  font-size: 32rpx;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 140rpx;
  width: 110rpx;
  height: 110rpx;
  background: var(--primary-gradient);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 226, 0.4);
  z-index: 100;
}

.fab-icon {
  font-size: 60rpx;
  color: var(--text-inverse);
  font-weight: 300;
  line-height: 1;
}

.filter-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.filter-panel {
  width: 100%;
  max-height: 80vh;
  background: var(--bg-card);
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
}

.filter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.filter-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.filter-reset {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.filter-body {
  flex: 1;
  padding: 30rpx;
  max-height: 60vh;
}

.filter-section {
  margin-bottom: 36rpx;
}

.filter-label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  display: block;
}

.filter-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-chip {
  padding: 14rpx 28rpx;
  background: var(--bg-page);
  border-radius: 32rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  border: 2rpx solid transparent;
}

.filter-chip.active {
  background: var(--primary-light);
  color: var(--primary-color);
  border-color: var(--primary-color);
  font-weight: 500;
}

.date-range {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.date-picker {
  flex: 1;
  padding: 20rpx 24rpx;
  background: var(--bg-page);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  text-align: center;
}

.date-sep {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

.filter-footer {
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--border-color);
}

.filter-apply-btn {
  width: 100%;
  padding: 28rpx;
  background: var(--primary-gradient);
  color: var(--text-inverse);
  text-align: center;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 500;
}
