<view class="page">
  <view class="header">
    <view class="header-top">
      <view class="greeting">
        <text class="greeting-text">记录生活的每一天 ✨</text>
      </view>
      <view class="header-actions">
        <view class="icon-btn" bindtap="toggleSearch">
          <text class="iconfont">🔍</text>
        </view>
      </view>
    </view>

    <view wx:if="{{showSearch}}" class="search-bar">
      <input
        class="search-input"
        placeholder="搜索日记..."
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        focus="{{showSearch}}"
      />
    </view>

    <view class="stats-bar">
      <view class="stat-item">
        <text class="stat-number">{{stats.total}}</text>
        <text class="stat-label">总篇数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-number">{{stats.thisMonth}}</text>
        <text class="stat-label">本月</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-number">{{stats.consecutiveDays}}</text>
        <text class="stat-label">连续天数</text>
      </view>
    </view>
  </view>

  <view class="diary-list">
    <block wx:if="{{diaryList.length > 0}}">
      <view
        class="diary-card card"
        wx:for="{{diaryList}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="goToDetail"
      >
        <view class="card-header">
          <view class="card-date">
            <text class="date-text">{{item.friendlyDate}}</text>
            <text class="mood">{{item.displayMood}}</text>
          </view>
          <view class="card-actions">
            <view class="card-ai-btn" data-id="{{item.id}}" catchtap="goToAiAnalyze">
              <text class="ai-icon">🤖</text>
            </view>
            <view class="card-type">
              <text wx:if="{{item.type === 'text'}}" class="type-tag">文字</text>
              <text wx:elif="{{item.type === 'voice'}}" class="type-tag">语音</text>
              <text wx:elif="{{item.type === 'image'}}" class="type-tag">图片</text>
              <text wx:elif="{{item.type === 'video'}}" class="type-tag">视频</text>
              <text wx:else class="type-tag">混合</text>
            </view>
          </view>
        </view>

        <view class="card-title" wx:if="{{item.title}}">
          {{item.title}}
        </view>

        <view class="card-content text-ellipsis-2" wx:if="{{item.content}}">
          {{item.content}}
        </view>

        <view class="card-images" wx:if="{{item.images && item.images.length > 0}}">
          <image
            wx:for="{{item.images}}"
            wx:for-item="img"
            wx:key="*this"
            src="{{img}}"
            class="card-image"
            mode="aspectFill"
          />
        </view>

        <view class="card-tags" wx:if="{{item.tags && item.tags.length > 0}}">
          <text class="tag" wx:for="{{item.tags}}" wx:key="*this">#{{item}}</text>
        </view>
      </view>
    </block>

    <view wx:else class="empty">
      <text class="empty-icon">📝</text>
      <text class="empty-text">还没有日记，开始记录吧</text>
    </view>
  </view>

  <view class="fab" bindtap="goToEdit">
    <text class="fab-icon">+</text>
  </view>
</view>
