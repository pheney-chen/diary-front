<view class="page {{theme === 'dark' ? 'theme-dark' : ''}}">
  <view class="header">
    <view class="header-top">
      <view class="greeting">
        <text class="greeting-text">记录生活的每一天 ✨</text>
      </view>
      <view class="header-actions">
        <view class="icon-btn" bindtap="toggleSearch">
          <text class="iconfont">🔍</text>
        </view>
      </view>
    </view>

    <view wx:if="{{showSearch}}" class="search-bar">
      <input
        class="search-input"
        placeholder="搜索日记..."
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        focus="{{showSearch}}"
      />
      <view class="filter-btn" bindtap="toggleFilterPanel">
        <text>筛选</text>
      </view>
    </view>

    <view class="stats-bar">
      <view class="stat-item">
        <text class="stat-number">{{stats.total}}</text>
        <text class="stat-label">总篇数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-number">{{stats.thisMonth}}</text>
        <text class="stat-label">本月</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-number">{{stats.consecutiveDays}}</text>
        <text class="stat-label">连续天数</text>
      </view>
    </view>

    <view wx:if="{{allTags.length > 0}}" class="tags-bar">
      <scroll-view scroll-x class="tags-scroll" enhanced show-scrollbar="{{false}}">
        <view class="tag-list">
          <view
            class="tag-chip {{selectedTag === '' ? 'active' : ''}}"
            bindtap="clearTagFilter"
          >
            <text>全部</text>
          </view>
          <view
            class="tag-chip {{selectedTag === item.name ? 'active' : ''}}"
            wx:for="{{allTags}}"
            wx:key="name"
            data-tag="{{item.name}}"
            bindtap="selectTag"
          >
            <text>#{{item.name}}</text>
            <text class="tag-count">{{item.count}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="diary-list">
    <block wx:if="{{diaryList.length > 0}}">
      <diary-card
        wx:for="{{diaryList}}"
        wx:key="id"
        diary="{{item}}"
        bind:tap="goToDetail"
        bind:ai="goToAiAnalyze"
      />
    </block>

    <view wx:else class="empty">
      <view class="empty-illustration">
        <text class="empty-icon">📔</text>
      </view>
      <text class="empty-title">开始你的第一篇日记</text>
      <text class="empty-desc">记录生活中的点滴美好</text>
      <view class="empty-action" bindtap="goToEdit">
        <text class="empty-action-icon">✏️</text>
        <text class="empty-action-text">写日记</text>
      </view>
    </view>
  </view>

  <view class="fab" bindtap="goToEdit">
    <text class="fab-icon">+</text>
  </view>

  <!-- 高级筛选面板 -->
  <view wx:if="{{showFilterPanel}}" class="filter-mask" bindtap="closeFilterPanel">
    <view class="filter-panel" catchtap="">
      <view class="filter-header">
        <text class="filter-title">高级筛选</text>
        <view class="filter-reset" bindtap="clearFilters">
          <text>重置</text>
        </view>
      </view>

      <scroll-view scroll-y class="filter-body">
        <view class="filter-section">
          <text class="filter-label">日记类型</text>
          <view class="filter-chips">
            <view
              class="filter-chip {{filter.type === item.key ? 'active' : ''}}"
              wx:for="{{typeOptions}}"
              wx:key="key"
              data-key="{{item.key}}"
              bindtap="selectFilterType"
            >
              <text>{{item.name}}</text>
            </view>
          </view>
        </view>

        <view class="filter-section">
          <text class="filter-label">心情</text>
          <view class="filter-chips">
            <view
              class="filter-chip {{filter.mood === 'all' ? 'active' : ''}}"
              data-key="all"
              bindtap="selectFilterMood"
            >
              <text>全部</text>
            </view>
            <view
              class="filter-chip {{filter.mood === item.key ? 'active' : ''}}"
              wx:for="{{moodList}}"
              wx:key="key"
              data-key="{{item.key}}"
              bindtap="selectFilterMood"
            >
              <text>{{item.emoji}} {{item.label}}</text>
            </view>
          </view>
        </view>

        <view class="filter-section">
          <text class="filter-label">标签</text>
          <view class="filter-chips">
            <view
              class="filter-chip {{filter.tag === 'all' ? 'active' : ''}}"
              data-tag="all"
              bindtap="selectFilterTag"
            >
              <text>全部</text>
            </view>
            <view
              class="filter-chip {{filter.tag === item.name ? 'active' : ''}}"
              wx:for="{{allTags}}"
              wx:key="name"
              data-tag="{{item.name}}"
              bindtap="selectFilterTag"
            >
              <text>#{{item.name}}</text>
            </view>
          </view>
        </view>

        <view class="filter-section">
          <text class="filter-label">日期范围</text>
          <view class="date-range">
            <picker mode="date" value="{{filter.startDate}}" bindchange="onStartDateChange">
              <view class="date-picker">
                <text>{{filter.startDate || '开始日期'}}</text>
              </view>
            </picker>
            <text class="date-sep">~</text>
            <picker mode="date" value="{{filter.endDate}}" bindchange="onEndDateChange">
              <view class="date-picker">
                <text>{{filter.endDate || '结束日期'}}</text>
              </view>
            </picker>
          </view>
        </view>
      </scroll-view>

      <view class="filter-footer">
        <view class="filter-apply-btn" bindtap="applyFilters">
          <text>应用筛选</text>
        </view>
      </view>
    </view>
  </view>
</view>
