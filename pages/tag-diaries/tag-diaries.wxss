.page {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 40rpx;
}

.tag-header {
  padding: 40rpx 30rpx 30rpx;
  background: var(--primary-gradient);
  color: #fff;
}

.tag-title {
  font-size: 40rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}

.tag-count {
  font-size: 26rpx;
  opacity: 0.8;
}

.diary-list {
  padding: 30rpx;
  margin-top: -10rpx;
}

.diary-card {
  margin-bottom: 24rpx;
  padding: 30rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-date {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.date-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.mood {
  font-size: 28rpx;
}

.type-tag {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  background: var(--primary-light);
  color: var(--primary-color);
  border-radius: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.card-content {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.card-images {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.card-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
  margin-bottom: 30rpx;
}

.empty-btn {
  padding: 20rpx 60rpx;
  background: var(--primary-gradient);
  color: #fff;
  border-radius: 50rpx;
  font-size: 28rpx;
}
