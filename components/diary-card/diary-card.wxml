<view class="diary-card card" bindtap="onCardTap">
  <view class="card-header">
    <view class="card-date">
      <text class="date-text">{{diary.friendlyDate}}</text>
      <text class="mood">{{displayMood}}</text>
    </view>
    <view class="card-actions">
      <view class="card-ai-btn" catchtap="onAiTap">
        <text class="ai-icon">🤖</text>
      </view>
      <view class="card-type">
        <text wx:if="{{diary.type === 'text'}}" class="type-tag">文字</text>
        <text wx:elif="{{diary.type === 'voice'}}" class="type-tag">语音</text>
        <text wx:elif="{{diary.type === 'image'}}" class="type-tag">图片</text>
        <text wx:elif="{{diary.type === 'video'}}" class="type-tag">视频</text>
        <text wx:else class="type-tag">混合</text>
      </view>
    </view>
  </view>

  <view class="card-title" wx:if="{{diary.title}}">
    {{diary.title}}
  </view>

  <view class="card-content text-ellipsis-2" wx:if="{{diary.content}}">
    {{diary.content}}
  </view>

  <view class="card-images" wx:if="{{diary.images && diary.images.length > 0}}">
    <image
      wx:for="{{diary.images}}"
      wx:for-item="img"
      wx:key="*this"
      src="{{img}}"
      class="card-image"
      mode="aspectFill"
    />
  </view>

  <view class="card-tags" wx:if="{{diary.tags && diary.tags.length > 0}}">
    <text class="tag" wx:for="{{diary.tags}}" wx:key="*this">#{{item}}</text>
  </view>
</view>
