# 微信开发者工具缓存
.project
.idea
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# 微信小程序编译缓存
miniprogram_npm/
node_modules/
package-lock.json
yarn.lock

# 日志文件
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 本地配置文件（含敏感信息）
project.private.config.json
project.config.json.bak
config.local.js
local.config.js

# 临时文件
*.tmp
*.temp
.cache/
.temp/

# 构建输出
dist/
build/
out/

# 测试覆盖率
coverage/

# 环境变量
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 备份文件
*.bak
*.backup
*.old
*.orig

# 压缩包
*.zip
*.tar.gz
*.rar

# 大文件（媒体资源可根据需要取消注释）
# assets/videos/
# assets/audio/

# 云开发本地调试
cloudfunctions/*/node_modules/
cloudfunctions/*/package-lock.json
